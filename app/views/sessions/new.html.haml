.mx-auto.max-w-2xl.py-32.sm:py-48.lg:py-56.flex.min-h-full.flex-col.justify-center.px-6.py-12.lg:px-8
  .sm:mx-auto.sm:w-full.sm:max-w-sm
    %img.mx-auto.h-10.w-auto{src: "https://tailwindui.com/plus/img/logos/mark.svg?color=indigo&shade=600"}
    %h2.mt-10.text-center.text-2xl.font-bold.leading-9.tracking-tight.text-gray-900
      Sign In

  .mt-10.sm:mx-auto.sm:w-full.sm:max-w-sm
    = form_with url: session_path, class: "space-y-6" do |f|
      %div
        = f.label :email_address, class: "block text-sm font-medium leading-6 text-gray-900"

        .mt-2
          = f.email_field :email_address, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"

      %div
        .flex.items-center.justify-between
          = f.label :password, class: "block text-sm font-medium leading-6 text-gray-900"

        .mt-2
          = f.password_field :password, class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6"

      %div
        = f.submit "Submit", class: "flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold leading-6 text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"

  %p.mt-10.text-center.text-sm.text-gray-500
    Not a member?

    = link_to "Sign up", new_registration_path, class: "font-semibold leading-6 text-indigo-600 hover:text-indigo-500"
