.pt-24.mx-8
  .flex.w-full.justify-between.my-8.items-center
    %h2.text-balance.text-3xl.font-semibold.tracking-tight.text-gray-900
      = "Folder #{@folder.name}"

    .flex.gap-x-4
      = link_to back_to_path(@folder), class: "inline-flex items-center border border-indigo-300 px-3 py-1.5 rounded-md text-indigo-500 hover:bg-indigo-50" do
        .size-6
          = render "icons/arrow_left"
        %span.ml-1.font-bold.text-lg Back

      .relative{data: {controller: "dropdown"}}
        %button.inline-flex.items-center.border.border-indigo-300.px-3.py-2.rounded-md.text-indigo-500.hover:bg-indigo-50{type: "button", data: { action: "dropdown#toggle click@window->dropdown#hide"} }
          .size-6
            = render "icons/arrow_down"
          %span.ml-1.font-bold.text-lg Download

        .hidden.bg-white.transition.transform.origin-top-right.absolute.right-0.border.border-gray-400.rounded.mt-2.divide-y.divide-gray-100{data: { "dropdown-target": "menu", transition: { enter: {from: "opacity-0 scale-95", to: "opacity-100 scale-100"}, leave: { from: "opacity-100 scale-100", to: "opacity-0 scale-95"}} }}
          = link_to "Version 1", download_api_v1_folder_path(@folder), class: "block px-4 py-2 text-gray-700 hover:text-indigo-500", data: { turbo: "false" }
          = link_to "Version 2", download_api_v2_folder_path(@folder), class: "block px-4 py-2 text-gray-700 hover:text-indigo-500", data: { turbo: "false" }

  .grid.grid-cols-4.gap-4
    - @folder.children.each do |folder|
      = render folder

    - @folder.binaries.each do |binary|
      = render binary
