.pt-24.mx-8
  .flex.w-full.justify-between.my-8.items-center
    %h2.text-balance.text-3xl.font-semibold.tracking-tight.text-gray-900
      = "Folder #{@folder.name}"

    .flex.gap-x-4
      = link_to back_to_path(@folder), class: "inline-flex items-center border border-indigo-300 px-3 py-1.5 rounded-md text-indigo-500 hover:bg-indigo-50" do
        .size-6
          = render "icons/arrow_left"
        %span.ml-1.font-bold.text-lg Back

      = link_to download_api_v1_folder_path(@folder), class: "inline-flex items-center border border-indigo-300 px-3 py-1.5 rounded-md text-indigo-500 hover:bg-indigo-50", data: { turbo: "false" } do
        .size-6
          = render "icons/arrow_down"
        %span.ml-1.font-bold.text-lg Download

  .grid.grid-cols-4.gap-4
    - @folder.children.each do |folder|
      = render folder

    - @folder.binaries.each do |binary|
      = render binary
