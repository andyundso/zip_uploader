.pt-24.mx-8
  .flex.w-full.justify-between.my-8.items-center
    %h2.text-balance.text-3xl.font-semibold.tracking-tight.text-gray-900
      = "Upload #{@upload.file_name}"

    = link_to uploads_path, class: "inline-flex items-center border border-indigo-300 px-3 py-1.5 rounded-md text-indigo-500 hover:bg-indigo-50" do
      .size-6
        = render "icons/arrow_left"
      %span.ml-1.font-bold.text-lg Back

  .grid.grid-cols-4.gap-4
    - @upload.folders.each do |folder|
      = render folder

    - @upload.binaries.each do |binary|
      = render binary
