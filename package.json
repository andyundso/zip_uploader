  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.12",
    "@stimulus-components/dropdown": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "esbuild": "^0.24.0",
    "playwright": "^1.47.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
